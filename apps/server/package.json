{
  "name": "@tidebase/server",
  "private": true,
  "version": "0.6.0",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepack": "pnpm build && rm -rf migrations && cp -R ../../migrations migrations"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "hono": "^4.6.16",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tidebase/sdk": "workspace:*",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "vitest": "^3.2.4"
  }
}
